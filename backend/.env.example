# ─── App ──────────────────────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Obtener en: supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Obtener en: supabase.com → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=tu-jwt-secret-de-supabase

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Claude API ───────────────────────────────────────────────────────────────
# Obtener en: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Transcripción ────────────────────────────────────────────────────────────
# Opciones: tiny, base, small, medium, large-v2, large-v3
# medium = rápido y preciso | large-v3 = más preciso pero 4x más lento
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# HuggingFace Token para pyannote (diarización de hablantes)
# Registro gratuito en: huggingface.co
# Luego aceptar términos en: huggingface.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=hf_...

# ─── Zoom API (Fase 5) ────────────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=

# ─── Microsoft Teams (Fase 6) ─────────────────────────────────────────────────
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# ─── Email - Resend (Fase 4) ──────────────────────────────────────────────────
# Registro gratuito en: resend.com (100 emails/día gratis)
RESEND_API_KEY=re_...
EMAIL_FROM=MeetingBoard <noreply@tudominio.com>

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BUCKET=meeting-recordings
MAX_UPLOAD_SIZE_MB=500

# ─── CORS (producción) ────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=["https://meetingboard.vercel.app"]
